{
    "name": "technoliga/plane-mcp",
    "description": "MCP server for Plane project management tool",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jon Hubbard",
            "email": "jon@technoliga.co.uk"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Technoliga\\PlaneMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Technoliga\\PlaneMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Technoliga\\PlaneMcp\\PlaneMcpServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}